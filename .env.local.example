# JWT secret cho session (>= 32 bytes)
JWT_SECRET=change-me-to-a-random-32-byte-hex-string

# Key mã hoá SQLite (SQLCipher AES-256, hex 64 chars = 32 bytes)
DB_KEY=change-me-to-a-random-32-byte-hex-string-64-chars-long-aaaa

# Thời gian hết hạn session (giờ)
SESSION_TTL_HOURS=8

# Đường dẫn DB (relative)
DB_PATH=./data/edurecruit.db

# Đường dẫn templates Word
TEMPLATES_DIR=./data/templates

# Đường dẫn backups
BACKUPS_DIR=./data/backups

# Cấu hình Sở GDĐT Lạng Sơn
ORG_NAME=Sở Giáo dục và Đào tạo Lạng Sơn
ORG_SHORT_NAME=Sở GDĐT Lạng Sơn

# App
NODE_ENV=development
LOG_LEVEL=info
